{
  "use_vllm": true,
  "vllm_endpoint": "http://localhost:8000/v1",
  "model_name": "unaizulaika/medgemma-1.5-4b-it-W4A16-G128",
  "batch_size": 8,
  "timeout": 150,
  "max_tokens": 32768,
  "context_window": 32768,
  "max_new_tokens_standard": 2048,
  "max_new_tokens_fast": 512,
  "structured_output": {
    "enabled": true,
    "backend": "auto"
  },
  "sanitize_fewshots": true,
  "history_splitting": {
    "enabled": true,
    "detection_thresholds": {
      "min_date_count": 3,
      "min_event_markers": 3,
      "min_distinct_treatment_types": 2
    },
    "max_events": 20,
    "max_new_tokens": 4096
  }
}