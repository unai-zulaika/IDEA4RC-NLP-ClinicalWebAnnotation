# Clinical Annotation Platform - Environment Configuration

# vLLM Server Configuration
# URL of the vLLM server for LLM inference
# Use host.docker.internal to reach the host machine from inside Docker containers
VLLM_API_URL=http://host.docker.internal:8000

# vLLM Docker image (change if your NVIDIA driver doesn't support the latest CUDA)
# For CUDA 12.4 / driver 550.x, use: vastai/vllm:v0.8.5-cuda-12.4-pytorch-2.6.0-py312
VLLM_IMAGE=vllm/vllm-openai:latest

# vLLM Model Configuration (used by docker-compose.vllm.yml)
VLLM_MODEL=unsloth/medgemma-27b-text-it-unsloth-bnb-4bit
VLLM_MAX_MODEL_LEN=16384
VLLM_MAX_NUM_SEQS=32
VLLM_GPU_MEM_UTIL=0.85
VLLM_HOST_PORT=8080
VLLM_EXTRA_ARGS=
# Eager mode flag (default: --enforce-eager, required for BitsAndBytes 4-bit quants).
# For GPTQ / W4A16 Marlin models (e.g. medgemma-1.5-4b-it-W4A16-G128), uncomment
# the line below to disable eager mode and enable CUDA graphs for better throughput.
# VLLM_ENFORCE_EAGER=
# HF_TOKEN=

# Backend API Configuration
# Port for the annotation API (default: 8001)
ANNOTATION_API_PORT=8001

# Frontend Configuration
# URL for the frontend to connect to the API.
#
# IMPORTANT: this value is BAKED INTO THE FRONTEND BUNDLE AT BUILD TIME and is
# evaluated by the browser, not by the container. So it must be a URL the
# browser can actually reach.
#
# Pick the right value for your deployment:
#
#   1. Single host, no reverse proxy, browser on the same host:
#        NEXT_PUBLIC_API_URL=http://localhost:8001
#
#   2. Single host, no reverse proxy, browser on a remote machine:
#        NEXT_PUBLIC_API_URL=http://<host-ip-or-domain>:8001
#      (localhost would resolve to the user's own laptop, not the server)
#
#   3. Behind a reverse proxy that routes /api/* to the backend:
#        NEXT_PUBLIC_API_URL=/api
#      (the empty/relative URL keeps all traffic going through the proxy)
#
# Because this is a build-time arg (passed to the Dockerfile via the `args:`
# block in docker-compose.yml, not via runtime `environment:`), the frontend
# container MUST be rebuilt WITHOUT CACHE after changing this value or Docker
# will reuse the previously baked-in URL:
#   docker compose build --no-cache annotation-web && docker compose up -d
#
# To verify the right value made it into the bundle, open DevTools in the
# browser, Network tab, and confirm API requests go to the URL you expect.
NEXT_PUBLIC_API_URL=http://localhost:8001

# Pipeline Configuration
# Path for pipeline results storage
APP_PATH=/data/results/data

# NLP Integration URLs (used by pipeline components)
NLP_BACKEND_URL=http://localhost:8001
NLP_FRONTEND_URL=http://localhost:3000
