# ============================================================
#  Clinical Annotation Platform: Hospital Configuration
#  Edit the values below, then run: ./deploy.sh
# ============================================================

# --- Kubernetes ---
NAMESPACE=clinical-annotation
STORAGE_CLASS=                  # Leave empty to use the cluster default

# --- Container Registry ---
REGISTRY=harbor.hospital.example.org/clinical
IMAGE_TAG=v1.0.0

# --- External LLM Endpoint (REQUIRED) ---
# Full URL of the OpenAI-compatible endpoint (must include /v1)
VLLM_ENDPOINT=http://gemma-vllm.llm-namespace.svc.cluster.local:8000/v1
# Model identifier expected by the endpoint
VLLM_MODEL_NAME=google/gemma-2-it

# --- Networking ---
DOMAIN=clinical.hospital.example.org
TLS_SECRET_NAME=                # Empty = no TLS; otherwise the name of an existing TLS Secret
INGRESS_CLASS=nginx

# --- Storage Sizes ---
SESSIONS_STORAGE=10Gi
FAISS_STORAGE=2Gi
PRESETS_STORAGE=1Gi
HF_CACHE_STORAGE=10Gi
PIPELINE_RESULTS_STORAGE=10Gi

# --- Resource Limits ---
API_CPU_REQUEST=500m
API_MEMORY_REQUEST=1Gi
API_CPU_LIMIT=2
API_MEMORY_LIMIT=4Gi

# --- Optional Components ---
DEPLOY_PIPELINE_SERVICES=false  # true to include pipeline-api and pipeline-dashboard
